# /docker/jellyfin/.env

COMPOSE_PROJECT_NAME=jellyfin

# Service Configuration
SERVICE=jellyfin
IMAGE_URL=lscr.io/linuxserver/jellyfin:latest
SERVICEPORT=8096

# Tailscale Configuration
# Example:
# TS_AUTHKEY=tskey-client-xxxxxxxxxxxxxxxx
TS_AUTHKEY=

# Jellyfin Container Configuration
PUID=1000
PGID=1000
TZ=America/New_York

# NVIDIA / GPU
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,video,utility

# Host Paths
CONFIG_PATH=./config
VIDEOS_PATH=/srv/mergerfs/data/root/Videos
SHOWS_PATH=/srv/mergerfs/data/root/Shows
MUSIC_PATH=/srv/mergerfs/data/root/Music
MOVIES_PATH=/srv/mergerfs/data/root/Movies
PICTURES_PATH=/srv/mergerfs/data/root/Photos