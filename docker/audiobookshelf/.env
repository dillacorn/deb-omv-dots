# /docker/audiobookshelf/.env

COMPOSE_PROJECT_NAME=audiobookshelf

# Service Configuration
SERVICE=audiobookshelf
IMAGE_URL=ghcr.io/advplyr/audiobookshelf:latest
SERVICEPORT=80

# Tailscale Configuration
# Example:
# TS_AUTHKEY=tskey-client-xxxxxxxxxxxxxxxx
TS_AUTHKEY=

# Container Configuration
PUID=1000
PGID=1000
TZ=America/New_York

# Host Paths
METADATA_PATH=./metadata
CONFIG_PATH=./config
AUDIOBOOKS_PATH=/srv/mergerfs/data/root/AudioBooks