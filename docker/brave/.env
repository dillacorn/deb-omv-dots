# /docker/brave/.env

COMPOSE_PROJECT_NAME=brave

# Service Configuration
SERVICE=brave
IMAGE_URL=lscr.io/linuxserver/brave:latest
SERVICEPORT=3000

# Tailscale Configuration
# Example:
# TS_AUTHKEY=tskey-client-xxxxxxxxxxxxxxxx
TS_AUTHKEY=

# Brave Configuration
PUID=1000
PGID=1000
TZ=America/New_York
CUSTOM_USER=username
PASSWORD=password