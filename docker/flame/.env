# /docker/flame/.env

COMPOSE_PROJECT_NAME=flame

# Service Configuration
SERVICE=flame
IMAGE_URL=ghcr.io/fdarveau/flame:latest

# Flame listens on 5005 by default
SERVICEPORT=5005

# Optional DNS override inside the tailscale container if you ever need it
DNS_SERVER=9.9.9.9

# Tailscale Configuration
# Example:
# TS_AUTHKEY=tskey-client-xxxxxxxxxxxxxxxx
TS_AUTHKEY=

# Flame Configuration
PASSWORD=password

# Optional
TZ=America/New_York
PUID=1000
PGID=1000