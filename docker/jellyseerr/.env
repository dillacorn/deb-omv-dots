# /docker/jellyseerr/.env

COMPOSE_PROJECT_NAME=jellyseerr

# Service Configuration
SERVICE=jellyseerr
IMAGE_URL=fallenbagel/jellyseerr:latest
SERVICEPORT=5055

# Tailscale Configuration
# Example:
# TS_AUTHKEY=tskey-client-xxxxxxxxxxxxxxxx
TS_AUTHKEY=

# App / DB Configuration
TZ=America/New_York
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_NAME=jellyseerr
DB_USER=username
DB_PASS=password

MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=jellyseerr
MYSQL_USER=username
MYSQL_PASSWORD=password

# Host Paths
JELLYSEERR_CONFIG_PATH=./jellyseerr/config
MARIADB_DATA_PATH=./mariadb_data